12.1.1. Phone Number Database Management

n = int(input())
contacts = {}

for i in range (n):
	cmd = input().split()
	if cmd[0] == "ADD":
		contacts[cmd[1]] = cmd[2]
	elif cmd[0] == "REMOVE":
		contacts.pop(cmd[1],None)
	elif cmd[0] == "DISPLAY":
		if len(contacts) == 0:
			print("No contacts")
		else:
			for name in sorted(contacts):
				print(f"{name}: {contacts[name]}")
